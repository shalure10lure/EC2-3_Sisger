{
	"name": "df_silver_unidades",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_unidades",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_tbl_unidades",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_unidad as integer,",
				"          id_brigada as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    id_unidad,\\n    id_brigada,\\n    TRIM(nombre) AS nombre,\\n    TRIM(codigo) AS codigo,\\n    TRIM(ciudad) AS ciudad,\\n    TRIM(departamento) AS departamento,\\n    TRIM(tipo_cuartel) AS tipo_cuartel\\nFROM bronze.tbl_unidades\\nWHERE id_unidad IS NOT NULL \\n  AND id_brigada IS NOT NULL\\n  AND TRIM(nombre) != \\'\\' \\n  AND UPPER(TRIM(nombre)) != \\'NULL\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(id_unidad = toInteger(id_unidad),",
				"          id_brigada = toInteger(id_brigada),",
				"          nombre = initCap(trim(nombre)),",
				"          codigo = upper(trim(codigo)),",
				"          ciudad = initCap(trim(ciudad)),",
				"          departamento = initCap(trim(departamento)),",
				"          tipo_cuartel = initCap(trim(tipo_cuartel))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_unidad as integer,",
				"          id_brigada as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_unidad,",
				"          id_brigada,",
				"          nombre,",
				"          codigo,",
				"          ciudad,",
				"          departamento,",
				"          tipo_cuartel",
				"     )) ~> sink1"
			]
		}
	}
}