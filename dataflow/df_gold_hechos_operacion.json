{
	"name": "df_gold_hechos_operacion",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_tbl_operaciones",
						"type": "DatasetReference"
					},
					"name": "operaciones"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "dimtiempo"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tipo_operacion",
						"type": "DatasetReference"
					},
					"name": "dimtipoperacion"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "dimunidad"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_zona_operacion",
						"type": "DatasetReference"
					},
					"name": "dimzona"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_operacion",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "lookup4"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as decimal(18,2),",
				"          incidentes as integer,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> operaciones",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimtiempo",
				"source(output(",
				"          tipo_operacion_key as integer,",
				"          tipo_id as integer,",
				"          nombre as string,",
				"          categoria as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimtipoperacion",
				"source(output(",
				"          unidad_key as integer,",
				"          unidad_id as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string,",
				"          brigada_id as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimunidad",
				"source(output(",
				"          zona_key as integer,",
				"          zona_id as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as integer,",
				"          nivel_riesgo as string,",
				"          acceso_carretero as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimzona",
				"operaciones, dimtiempo lookup(fecha_inicio == fecha,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, dimtipoperacion lookup(id_operacion == tipo_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2, dimunidad lookup(id_unidad_resp == unidad_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup3, dimzona lookup(id_zona == zona_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup4",
				"lookup4 select(mapColumn(",
				"          fecha_inicio,",
				"          fecha_fin,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          resultado,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          observaciones,",
				"          tipo_operacion_key,",
				"          unidad_key,",
				"          zona_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          operacion_key as integer,",
				"          fecha_inicio_key as integer,",
				"          fecha_fin_key as integer,",
				"          tipo_operacion_key as integer,",
				"          unidad_key as integer,",
				"          zona_key as integer,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          detenidos as integer,",
				"          area_km2 as decimal(18,2),",
				"          incidentes as integer,",
				"          resultado as string,",
				"          observaciones as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_inicio_key = fecha_inicio,",
				"          fecha_fin_key = fecha_fin,",
				"          tipo_operacion_key,",
				"          unidad_key,",
				"          zona_key,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          resultado,",
				"          observaciones",
				"     )) ~> sink1"
			]
		}
	}
}